# MOCK_MODE=true  →  streams pre-written sample responses, no API key needed
# MOCK_MODE=false →  calls the Gemini API (requires a real GEMINI_API_KEY)
MOCK_MODE=true

# Gemini API key (free tier: aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-flash-latest

# Comma-separated list of frontend origins allowed to call this API, e.g.
# "http://localhost:3000,https://testforge.vercel.app"
FRONTEND_ORIGINS=http://localhost:3000
